# ── SUPABASE ──────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── STRIPE ────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Get webhook secret by running: stripe listen --forward-to localhost:3000/api/checkout/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── ANTHROPIC (ARIA CHATBOT + STYLE TIPS) ─────────────────────
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── MAPBOX (STORE LOCATOR MAP) ────────────────────────────────
# Get from: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# ── RESEND (EMAIL CONFIRMATIONS) ──────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@top10prom.com

# ── PERFECT CORP (VIRTUAL TRY-ON) ─────────────────────────────
# Get from: https://developer.perfectcorp.com
# Leave blank to use fallback CSS overlay demo
# IMPORTANT: Use the publishable/app key here (NOT a secret key starting with sk-)
# If you only have a secret key, move all Perfect Corp calls to a server-side API route
# and store the secret key as PERFECTCORP_API_KEY (without NEXT_PUBLIC_)
NEXT_PUBLIC_PERFECTCORP_API_KEY=your_publishable_app_key_here
PERFECTCORP_API_KEY=your_secret_key_here

# ── GOOGLE OAUTH (SUPABASE SOCIAL LOGIN) ──────────────────────
# Configure in Supabase Dashboard → Authentication → Providers → Google
# Add your Google Cloud OAuth credentials there directly (not in .env)

# ── SITE CONFIG ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Top 10 Prom

# ── UPSTASH REDIS (RATE LIMITING) ─────────────────────────────
# Get from: https://console.upstash.com → Create Database → REST API
# Required to enable rate limiting on AI API routes (/api/chat, /api/tryon/suggest, /api/tux/match)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── TASKMASTER (MCP) ──────────────────────────────────────────
# TaskMaster AI MCP server API key
TASK_MASTER_TOOLS=your_taskmaster_key_here
